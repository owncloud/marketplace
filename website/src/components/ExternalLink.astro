---
// A link to another origin. Centralizes the security treatment for outbound
// *navigation* links (not file downloads): opens in a new tab, drops the
// opener handle and Referer header, and tells crawlers not to pass ranking
// (rel="noopener noreferrer nofollow"). The `data-external-link` marker is the
// single hook the global leave-notice handler in Base.astro keys off to show a
// "you're leaving the Marketplace" confirmation before navigating.
//
// Any extra attributes (aria-label, title, …) are forwarded to the anchor.
interface Props {
  href: string;
  class?: string;
  [key: string]: unknown;
}
const { href, class: className, ...rest } = Astro.props;
---
<a
  href={href}
  class={className}
  target="_blank"
  rel="noopener noreferrer nofollow"
  data-external-link
  {...rest}
><slot /></a>
