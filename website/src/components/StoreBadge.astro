---
// Official-style app-store badges for the mobile surfaces on the Downloads page.
// Each badge reproduces the platform's mandated lockup — black rounded plate,
// the official mark, and the two-line label — so it stays recognisable and
// guideline-faithful while remaining crisp at any size (text is real text, not
// a flattened bitmap). The Apple mark is traced from simple-icons' Apple glyph;
// the Google Play triangle uses Google's four official brand colours.
//
// The store URL points off-site, so the badge routes through ExternalLink to
// inherit the Marketplace's outbound-link security and leave-notice treatment.
import ExternalLink from "./ExternalLink.astro";
interface Props {
  store: "ios" | "android";
  href: string;
  class?: string;
}
const { store, href, class: className } = Astro.props;

const LABEL = {
  ios: "Download ownCloud on the App Store",
  android: "Get ownCloud on Google Play",
} as const;
---
<ExternalLink
  class:list={["store-badge", `store-badge--${store}`, className]}
  href={href}
  aria-label={LABEL[store]}
>
  {store === "ios" ? (
    <svg class="store-badge__mark" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
      <path
        fill="currentColor"
        d="M12.152 6.896c-.948 0-2.415-1.078-3.96-1.04-2.04.027-3.91 1.183-4.961 3.014-2.117 3.675-.546 9.103 1.519 12.09 1.013 1.454 2.208 3.09 3.792 3.039 1.52-.065 2.09-.987 3.935-.987 1.831 0 2.35.987 3.96.948 1.637-.026 2.676-1.48 3.676-2.948 1.156-1.688 1.636-3.325 1.662-3.415-.039-.013-3.182-1.221-3.22-4.857-.026-3.04 2.48-4.494 2.597-4.559-1.429-2.09-3.623-2.324-4.39-2.376-2-.156-3.675 1.09-4.61 1.09zM15.53 3.83c.843-1.012 1.4-2.427 1.245-3.83-1.207.052-2.662.805-3.532 1.818-.78.896-1.454 2.338-1.273 3.714 1.338.104 2.715-.688 3.559-1.701"
      />
    </svg>
    <span class="store-badge__text">
      <span class="store-badge__lead">Download on the</span>
      <span class="store-badge__title">App Store</span>
    </span>
  ) : (
    <svg class="store-badge__mark" viewBox="30 336.7 120.9 129.2" aria-hidden="true" focusable="false">
      <path fill="#00d3ff" d="M99.1,401.1l-64.3-64.3c-2.6,0.6-4.8,2.9-4.8,7.6c0,7.5,0,107.5,0,113.8c0,4.3,1.7,7.4,4.9,7.7L99.1,401.1z" />
      <path fill="#00f076" d="M99.1,401.1l20.1-20.2c0,0-74.6-40.7-79.1-43.1c-1.7-1-3.6-1.3-5.3-1L99.1,401.1z" />
      <path fill="#ffce00" d="M119.2,421.2c15.3-8.4,27-14.8,28-15.3c3.2-1.7,6.5-6.2,0-9.7c-2.1-1.1-13.4-7.3-28-15.3l-20.1,20.2L119.2,421.2z" />
      <path fill="#ff3a44" d="M99.1,401.1l-64.2,64.7c1.5,0.2,3.2-0.2,5.2-1.3c4.2-2.3,48.8-26.7,79.1-43.3L99.1,401.1L99.1,401.1z" />
    </svg>
    <span class="store-badge__text">
      <span class="store-badge__lead">Get it on</span>
      <span class="store-badge__title">Google Play</span>
    </span>
  )}
</ExternalLink>

<style>
  .store-badge {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    height: 52px;
    padding: 0 18px;
    border-radius: 10px;
    background: #000;
    color: #fff;
    border: 1px solid rgba(255, 255, 255, 0.18);
    line-height: 1;
    transition:
      transform 0.16s ease,
      box-shadow 0.16s ease;
  }
  .store-badge:hover {
    text-decoration: none;
    transform: translateY(-2px);
    box-shadow: var(--shadow-md);
  }
  .store-badge:focus-visible {
    outline: 3px solid var(--oc-primary);
    outline-offset: 3px;
  }

  .store-badge__mark {
    flex: none;
    height: 26px;
    width: auto;
  }
  /* Apple's mark sits optically high; nudge it onto the baseline of the text. */
  .store-badge--ios .store-badge__mark {
    height: 28px;
    margin-top: -3px;
  }

  .store-badge__text {
    display: flex;
    flex-direction: column;
    gap: 2px;
    text-align: left;
  }
  .store-badge__lead {
    font-size: 0.62rem;
    font-weight: 500;
    letter-spacing: 0.01em;
  }
  .store-badge--android .store-badge__lead {
    text-transform: uppercase;
    letter-spacing: 0.12em;
  }
  .store-badge__title {
    font-size: 1.22rem;
    font-weight: 600;
    letter-spacing: 0.01em;
  }
</style>
