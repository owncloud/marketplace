---
import Base from "../layouts/Base.astro";
import { withBase } from "../lib/catalog.ts";
const base = import.meta.env.BASE_URL;
---
<Base
  title="Page not found — ownCloud Marketplace"
  description="The page you were looking for doesn't exist. Head back to the ownCloud Marketplace catalog to find apps and extensions."
>
  <section class="notfound">
    <div class="notfound__grid" aria-hidden="true"></div>
    <div class="notfound__glow" aria-hidden="true"></div>
    <div class="container notfound__inner">
      <p class="notfound__code" aria-hidden="true">404</p>
      <p class="eyebrow">Page not found</p>
      <h1 class="notfound__title">
        This page took a <span class="notfound__accent">wrong turn</span>.
      </h1>
      <p class="notfound__lede">
        The app, extension, or page you're looking for may have moved, been
        renamed, or never existed. Let's get you back to something that does.
      </p>
      <div class="notfound__actions">
        <a class="btn btn--solid" href={withBase(base, "")}
          >Back to the catalog</a
        >
        <a class="btn btn--ghost" href={withBase(base, "extensions")}
          >Browse Web Extensions</a
        >
      </div>
      <p class="notfound__hint">
        Looking for a specific app? <a href={withBase(base, "#catalog")}
          >Search the catalog →</a
        >
      </p>
    </div>
  </section>
</Base>

<style>
  .notfound {
    position: relative;
    overflow: hidden;
    min-height: 60vh;
    display: flex;
    align-items: center;
    background: radial-gradient(
      130% 100% at 80% -10%,
      #1d3a66 0%,
      var(--oc-brand) 55%,
      #03152f 100%
    );
    color: #fff;
    isolation: isolate;
  }
  .notfound__grid {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(255, 255, 255, 0.05) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255, 255, 255, 0.05) 1px, transparent 1px);
    background-size: 48px 48px;
    mask-image: radial-gradient(120% 80% at 50% 0%, #000 30%, transparent 78%);
    z-index: -1;
  }
  .notfound__glow {
    position: absolute;
    width: 620px;
    height: 620px;
    right: -160px;
    top: -260px;
    border-radius: 50%;
    background: radial-gradient(
      circle,
      rgba(74, 118, 172, 0.55),
      transparent 65%
    );
    filter: blur(20px);
    z-index: -1;
  }
  .notfound__inner {
    padding-block: 96px 84px;
    max-width: 720px;
  }
  .notfound__code {
    font-family: var(--font-mono);
    font-size: clamp(3.5rem, 12vw, 7rem);
    font-weight: 500;
    line-height: 1;
    margin: 0 0 8px;
    color: rgba(143, 180, 227, 0.55);
    letter-spacing: 0.04em;
  }
  .eyebrow {
    text-transform: uppercase;
    letter-spacing: 0.18em;
    font-size: 0.74rem;
    font-weight: 700;
    color: #8fb4e3;
    margin: 0 0 20px;
  }
  .notfound__title {
    font-size: clamp(2.2rem, 5vw, 3.4rem);
    font-weight: 700;
    margin: 0 0 22px;
  }
  .notfound__accent {
    position: relative;
    white-space: nowrap;
  }
  .notfound__accent::after {
    content: "";
    position: absolute;
    left: 0;
    right: 0;
    bottom: 0.08em;
    height: 0.14em;
    background: linear-gradient(90deg, #4a76ac, #8fb4e3);
    border-radius: 2px;
  }
  .notfound__lede {
    font-size: clamp(1.05rem, 2vw, 1.25rem);
    color: rgba(255, 255, 255, 0.82);
    max-width: 560px;
    margin: 0 0 34px;
  }
  .notfound__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 14px;
    margin-bottom: 28px;
  }
  .notfound__hint {
    font-size: 0.95rem;
    color: rgba(255, 255, 255, 0.72);
    margin: 0;
  }
  .notfound__hint a {
    color: #8fb4e3;
    font-weight: 600;
  }
  .notfound__hint a:hover {
    color: #fff;
  }

  /* ---------- Buttons (mirrors index.astro hero buttons) ---------- */
  .btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-weight: 600;
    font-size: 1rem;
    padding: 13px 24px;
    border-radius: 999px;
    transition:
      transform 0.18s ease,
      background 0.18s ease,
      box-shadow 0.18s ease,
      border-color 0.18s ease;
  }
  .btn:hover {
    text-decoration: none;
    transform: translateY(-2px);
  }
  .btn--solid {
    background: #fff;
    color: var(--oc-brand);
    box-shadow: 0 10px 30px -12px rgba(0, 0, 0, 0.5);
  }
  .btn--solid:hover {
    box-shadow: 0 16px 40px -14px rgba(0, 0, 0, 0.6);
  }
  .btn--ghost {
    color: #fff;
    border: 1px solid rgba(255, 255, 255, 0.4);
  }
  .btn--ghost:hover {
    border-color: #fff;
    background: rgba(255, 255, 255, 0.08);
  }
</style>
