---
import Base from "../layouts/Base.astro";
import ExternalLink from "../components/ExternalLink.astro";
import { loadDownloads, withBase, type DownloadSurface } from "../lib/catalog.ts";
import { SURFACES } from "../lib/downloads.ts";

// The canonical download index — successor to download.owncloud.com. It is
// styled as a plain file-server directory listing (the autoindex the old
// domain served), but every entry is generated from the GitHub release data
// the project already collects into _site/api/v1/downloads.json. The tree is
// product/ → version/ → file, mirroring how the artifacts are actually laid
// out. ocis and the Classic server ship direct binaries; the desktop client
// and the mobile apps publish via GitHub/app stores, so their version folders
// link out to the release page.
const downloads = await loadDownloads();
const base = import.meta.env.BASE_URL;

// The on-disk directory name for each surface — mirrors download.owncloud.com's
// own top-level folders where they existed (desktop/, ocis/, server/).
const DIR_NAMES: Record<string, string> = {
  ocis: "ocis",
  server: "server",
  client: "desktop",
  android: "android",
  ios: "ios",
};

const surfaces = SURFACES.map((s) => ({
  ...s,
  dir: DIR_NAMES[s.key] ?? s.key,
  surface: (downloads?.[s.key] ?? null) as DownloadSurface | null,
}));

// Apache/nginx autoindex date style, e.g. "2026-05-22 08:59" (UTC).
const fmtIndexDate = (iso: string): string => {
  const d = new Date(iso);
  return Number.isNaN(d.getTime()) ? iso : d.toISOString().slice(0, 16).replace("T", " ");
};

// Last path segment of a download URL — the artifact's real file name.
const fileName = (url: string): string => url.split("/").pop() || url;

const generated = downloads ? fmtIndexDate(downloads.generatedAt) : null;

// PGP signing keys, vendored under website/public/keys/ so verification keeps
// working once download.owncloud.com is retired. Values match the original
// index listing; sizes are the vendored files'.
const keys = [
  {
    name: "owncloud.asc",
    href: withBase(base, "keys/owncloud.asc"),
    size: "3.1 KB",
    modified: "2022-09-21 05:45",
  },
  {
    name: "owncloud-oem-pubkey.asc",
    href: withBase(base, "keys/owncloud-oem-pubkey.asc"),
    size: "1.3 KB",
    modified: "2019-07-09 13:59",
  },
];
---
<Base
  title="Index of ownCloud downloads"
  description="Directory index of every ownCloud release — Infinite Scale, Classic 10 server, the desktop client and the Android & iOS apps — generated from the official GitHub sources."
>
  <header class="idx-head">
    <div class="container">
      <h1 class="idx-head__title">Index of ownCloud downloads</h1>
      <p class="idx-head__path">/</p>
      {generated && <p class="idx-head__note">Generated {generated} UTC from the official release sources.</p>}
    </div>
  </header>

  <div class="container">
    <div class="idx" role="table" aria-label="Download directory listing">
      <div class="idx__head" role="row">
        <span class="idx__c idx__c--name">Name</span>
        <span class="idx__c idx__c--date">Last modified</span>
        <span class="idx__c idx__c--size">Size</span>
        <span class="idx__c idx__c--desc">Description</span>
      </div>
      <div class="idx__rule" aria-hidden="true"></div>

      {
        surfaces.map(({ key, name, tagline, repo, dir, surface }) => (
          <>
            <div class="idx__row idx__row--dir" id={dir} role="row">
              <span class="idx__c idx__c--name">
                <span class="idx__icon" aria-hidden="true">📁</span>
                <span class="idx__dir">{dir}/</span>
              </span>
              <span class="idx__c idx__c--date">{surface ? fmtIndexDate(surface.publishedAt) : "-"}</span>
              <span class="idx__c idx__c--size">-</span>
              <span class="idx__c idx__c--desc">{name} — {tagline}</span>
            </div>

            {surface ? (
              surface.releases.map((r) => (
                <>
                  <div class="idx__row idx__row--ver" role="row">
                    <span class="idx__c idx__c--name idx__indent-1">
                      <span class="idx__icon" aria-hidden="true">📁</span>
                      <ExternalLink class="idx__link" href={r.releaseUrl}>
                        {r.version}/
                      </ExternalLink>
                    </span>
                    <span class="idx__c idx__c--date">{fmtIndexDate(r.publishedAt)}</span>
                    <span class="idx__c idx__c--size">-</span>
                    <span class="idx__c idx__c--desc">
                      {r.binaries.length === 0 && "release on GitHub"}
                    </span>
                  </div>

                  {r.binaries.map((b) => (
                    <div class="idx__row idx__row--file" role="row">
                      <span class="idx__c idx__c--name idx__indent-2">
                        <span class="idx__icon" aria-hidden="true">📄</span>
                        <a class="idx__link" href={b.url} rel="noopener">
                          {fileName(b.url)}
                        </a>
                      </span>
                      <span class="idx__c idx__c--date">{fmtIndexDate(r.publishedAt)}</span>
                      <span class="idx__c idx__c--size">{b.size}</span>
                      <span class="idx__c idx__c--desc">{[b.os, b.arch].filter(Boolean).join(" ")}</span>
                    </div>
                  ))}
                </>
              ))
            ) : (
              <div class="idx__row idx__row--file" role="row">
                <span class="idx__c idx__c--name idx__indent-1 idx__muted">
                  (no release data — <ExternalLink class="idx__link" href={`https://github.com/${repo}/releases`}>browse on GitHub</ExternalLink>)
                </span>
                <span class="idx__c idx__c--date">-</span>
                <span class="idx__c idx__c--size">-</span>
                <span class="idx__c idx__c--desc" />
              </div>
            )}
          </>
        ))
      }

      {/* Top-level signing keys, as on the original index root. */}
      <div class="idx__rule idx__rule--soft" aria-hidden="true"></div>
      {
        keys.map((k) => (
          <div class="idx__row idx__row--file" role="row">
            <span class="idx__c idx__c--name">
              <span class="idx__icon" aria-hidden="true">🔑</span>
              <a class="idx__link" href={k.href} download>
                {k.name}
              </a>
            </span>
            <span class="idx__c idx__c--date">{k.modified}</span>
            <span class="idx__c idx__c--size">{k.size}</span>
            <span class="idx__c idx__c--desc">PGP signing key</span>
          </div>
        ))
      }
      <div class="idx__rule" aria-hidden="true"></div>
    </div>
  </div>
</Base>

<style>
  /* ---------- Slim, utilitarian header (not a marketing hero) ---------- */
  .idx-head {
    background: var(--oc-brand);
    color: #fff;
    border-bottom: 1px solid var(--oc-border);
  }
  .idx-head .container {
    padding-block: 30px 26px;
  }
  .idx-head__title {
    font-size: clamp(1.4rem, 3vw, 1.9rem);
    font-weight: 700;
    margin: 0;
  }
  .idx-head__path {
    font-family: var(--font-mono);
    font-size: 0.95rem;
    color: #8fb4e3;
    margin: 6px 0 0;
  }
  .idx-head__note {
    font-size: 0.84rem;
    color: rgba(255, 255, 255, 0.7);
    margin: 10px 0 0;
  }

  /* ---------- Directory autoindex ---------- */
  .idx {
    font-family: var(--font-mono);
    font-size: 0.86rem;
    line-height: 1.5;
    color: var(--oc-text);
    margin: 28px 0 96px;
    overflow-x: auto;
  }
  .idx__head {
    font-weight: 600;
    color: var(--oc-text-muted);
  }
  .idx__head,
  .idx__row {
    display: grid;
    grid-template-columns: minmax(280px, 1fr) 160px 90px minmax(160px, 1fr);
    gap: 16px;
    padding: 3px 8px;
    align-items: baseline;
  }
  .idx__rule {
    height: 0;
    border-top: 1px solid var(--oc-text-muted);
    margin: 4px 0;
  }
  .idx__rule--soft {
    border-top-style: dashed;
    border-top-color: var(--oc-border-input);
  }
  .idx__row:hover {
    background: var(--oc-bg-highlight);
  }
  .idx__c {
    min-width: 0;
  }
  .idx__c--name {
    display: flex;
    align-items: baseline;
    gap: 8px;
    overflow-wrap: anywhere;
  }
  .idx__c--date,
  .idx__c--size {
    color: var(--oc-text-muted);
    white-space: nowrap;
  }
  .idx__c--size {
    text-align: right;
  }
  .idx__c--desc {
    color: var(--oc-text-muted);
    overflow-wrap: anywhere;
  }
  .idx__icon {
    flex: none;
  }
  .idx__dir {
    font-weight: 700;
    color: var(--oc-brand);
  }
  .idx__row--ver .idx__link {
    font-weight: 600;
  }
  .idx__indent-1 {
    padding-left: 22px;
  }
  .idx__indent-2 {
    padding-left: 44px;
  }
  .idx__muted {
    color: var(--oc-text-muted);
  }
  .idx__link {
    color: var(--oc-primary-hover);
  }

  /* Drop the Description column on narrow screens; the listing scrolls if the
     remaining columns still overflow. */
  @media (max-width: 720px) {
    .idx__head,
    .idx__row {
      grid-template-columns: minmax(220px, 1fr) 140px 80px;
    }
    .idx__c--desc {
      display: none;
    }
  }
</style>
