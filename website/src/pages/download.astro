---
import Base from "../layouts/Base.astro";
import ExternalLink from "../components/ExternalLink.astro";
import StoreBadge from "../components/StoreBadge.astro";
import { loadDownloads, withBase, type DownloadSurface } from "../lib/catalog.ts";
import { SURFACES } from "../lib/downloads.ts";

// The canonical download directory — successor to download.owncloud.com. Every
// product and every version come straight from the GitHub release data the
// project already fetches into _site/api/v1/downloads.json; no values are
// hardcoded here. ocis and the Classic server ship direct binaries on each
// release; the desktop client and the mobile apps publish via GitHub/app
// stores, so those releases link out instead.
const downloads = await loadDownloads();
const base = import.meta.env.BASE_URL;

const surfaces = SURFACES.map((s) => ({
  ...s,
  surface: (downloads?.[s.key] ?? null) as DownloadSurface | null,
}));

// "2026-02-01T…" → "1 Feb 2026"; matches the downloads landing/history pages.
const fmtDate = (iso: string): string => {
  const d = new Date(iso);
  return Number.isNaN(d.getTime())
    ? iso
    : d.toLocaleDateString("en-GB", { day: "numeric", month: "short", year: "numeric" });
};

const fmtCount = (n: number) => n.toLocaleString("en-US");
const fmtDownloads = (n: number) => `${fmtCount(n)} download${n === 1 ? "" : "s"}`;

const generated = downloads ? fmtDate(downloads.generatedAt) : null;

// PGP signing keys, vendored under website/public/keys/ so they keep resolving
// once download.owncloud.com is retired. Used to verify release artifacts.
const keys = [
  {
    name: "owncloud.asc",
    href: withBase(base, "keys/owncloud.asc"),
    note: "Primary release signing key",
  },
  {
    name: "owncloud-oem-pubkey.asc",
    href: withBase(base, "keys/owncloud-oem-pubkey.asc"),
    note: "OEM signing key",
  },
];
---
<Base
  title="Downloads — ownCloud"
  description="Every release of every ownCloud product — Infinite Scale, Classic 10 server, the desktop client and the Android & iOS apps — with direct download links, straight from the official GitHub sources."
>
  <!-- ===================== HERO ===================== -->
  <section class="hero">
    <div class="hero__grid" aria-hidden="true"></div>
    <div class="hero__glow" aria-hidden="true"></div>
    <div class="container hero__inner">
      <p class="eyebrow">Open Source Program Office · Releases</p>
      <h1 class="hero__title">Download <span class="hero__accent">ownCloud</span>.</h1>
      <p class="hero__lede">
        Every release of every ownCloud product — Infinite Scale, Classic 10
        server, the desktop client and the Android &amp; iOS apps — pulled
        straight from the official sources.
      </p>
      {generated && <p class="hero__note">Release data refreshed {generated}.</p>}
    </div>
  </section>

  <!-- ===================== JUMP NAV ===================== -->
  <nav class="jump container" aria-label="Jump to a product">
    {
      surfaces.map(({ key, name }) => (
        <a class="jump__link" href={`#${key}`}>
          {name}
        </a>
      ))
    }
    <a class="jump__link" href="#keys">Signing keys</a>
  </nav>

  <!-- ===================== PRODUCTS ===================== -->
  <div class="container products">
    {
      surfaces.map(({ key, name, tagline, repo, surface }) => (
        <section class="product" id={key}>
          <header class="product__head">
            <div>
              <h2 class="product__name">{name}</h2>
              <p class="product__tagline">{tagline}</p>
            </div>
            {surface && (
              <p class="product__meta">
                <span>Latest v{surface.version}</span>
                <span class="dot" aria-hidden="true">·</span>
                <span>{fmtDate(surface.publishedAt)}</span>
                {surface.downloads > 0 && (
                  <>
                    <span class="dot" aria-hidden="true">·</span>
                    <span>{fmtDownloads(surface.downloads)}</span>
                  </>
                )}
              </p>
            )}
          </header>

          {surface?.store && (key === "ios" || key === "android") && (
            <div class="product__store">
              <StoreBadge store={key} href={surface.store.url} />
            </div>
          )}

          {surface ? (
            <ul class="releases">
              {surface.releases.map((r, i) => (
                <li class="release">
                  <div class="release__head">
                    <ExternalLink class="release__version" href={r.releaseUrl}>
                      v{r.version}
                    </ExternalLink>
                    {i === 0 && <span class="release__badge">Latest</span>}
                    <span class="release__date">{fmtDate(r.publishedAt)}</span>
                  </div>
                  {r.downloads > 0 && (
                    <div class="release__facts">
                      <span>{fmtDownloads(r.downloads)}</span>
                    </div>
                  )}
                  {r.binaries.length > 0 ? (
                    <ul class="downloads">
                      {r.binaries.map((b) => (
                        <li>
                          <a class="download" href={b.url} rel="noopener">
                            <span class="download__os">{b.os}</span>
                            {b.arch && <span class="download__arch">{b.arch}</span>}
                            <span class="download__size">{b.size}</span>
                          </a>
                        </li>
                      ))}
                    </ul>
                  ) : (
                    <p class="release__fallback">
                      No direct binaries listed.{" "}
                      <ExternalLink href={r.releaseUrl}>
                        Browse this release on GitHub →
                      </ExternalLink>
                    </p>
                  )}
                </li>
              ))}
            </ul>
          ) : (
            <p class="release__fallback">
              No release data is available yet.{" "}
              <ExternalLink href={`https://github.com/${repo}/releases`}>
                Browse releases on GitHub →
              </ExternalLink>
            </p>
          )}
        </section>
      ))
    }

    <!-- ===================== SIGNING KEYS ===================== -->
    <section class="product" id="keys">
      <header class="product__head">
        <div>
          <h2 class="product__name">PGP signing keys</h2>
          <p class="product__tagline">
            Verify the authenticity of downloaded release artifacts against these
            public keys.
          </p>
        </div>
      </header>
      <ul class="downloads">
        {
          keys.map((k) => (
            <li>
              <a class="download" href={k.href} download>
                <span class="download__os">{k.name}</span>
                <span class="download__arch">{k.note}</span>
              </a>
            </li>
          ))
        }
      </ul>
    </section>
  </div>
</Base>

<style>
  /* ---------- Hero (shared visual language with the downloads page) ---------- */
  .hero {
    position: relative;
    overflow: hidden;
    background:
      radial-gradient(130% 100% at 80% -10%, #1d3a66 0%, var(--oc-brand) 55%, #03152f 100%);
    color: #fff;
    isolation: isolate;
  }
  .hero__grid {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(255, 255, 255, 0.05) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255, 255, 255, 0.05) 1px, transparent 1px);
    background-size: 48px 48px;
    mask-image: radial-gradient(120% 80% at 50% 0%, #000 30%, transparent 78%);
    z-index: -1;
  }
  .hero__glow {
    position: absolute;
    width: 620px;
    height: 620px;
    right: -160px;
    top: -260px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(74, 118, 172, 0.55), transparent 65%);
    filter: blur(20px);
    z-index: -1;
  }
  .hero__inner {
    padding-block: 84px 72px;
    max-width: 860px;
  }
  .eyebrow {
    text-transform: uppercase;
    letter-spacing: 0.18em;
    font-size: 0.74rem;
    font-weight: 700;
    color: #8fb4e3;
    margin: 0 0 20px;
  }
  .hero__title {
    font-size: clamp(2.4rem, 6vw, 4rem);
    font-weight: 700;
    margin: 0 0 22px;
  }
  .hero__accent {
    position: relative;
    white-space: nowrap;
  }
  .hero__accent::after {
    content: "";
    position: absolute;
    left: 0;
    right: 0;
    bottom: 0.08em;
    height: 0.14em;
    background: linear-gradient(90deg, #4a76ac, #8fb4e3);
    border-radius: 2px;
  }
  .hero__lede {
    font-size: clamp(1.05rem, 2vw, 1.25rem);
    color: rgba(255, 255, 255, 0.82);
    max-width: 620px;
    margin: 0 0 18px;
  }
  .hero__note {
    font-size: 0.86rem;
    color: #8fb4e3;
    margin: 0;
  }

  /* ---------- Jump nav ---------- */
  .jump {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    padding-top: 32px;
  }
  .jump__link {
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--oc-primary-hover);
    padding: 7px 14px;
    border: 1px solid var(--oc-border-input);
    border-radius: 999px;
    background: var(--oc-bg);
    transition:
      background 0.16s ease,
      border-color 0.16s ease;
  }
  .jump__link:hover {
    text-decoration: none;
    background: var(--oc-bg-highlight);
    border-color: var(--oc-primary);
  }

  /* ---------- Products ---------- */
  .products {
    padding-top: 40px;
    display: grid;
    gap: 40px;
  }
  /* Offset anchor targets so the sticky header doesn't cover the heading. */
  .product {
    scroll-margin-top: 88px;
  }
  .product__head {
    display: flex;
    flex-wrap: wrap;
    align-items: flex-start;
    justify-content: space-between;
    gap: 8px 24px;
    padding-bottom: 16px;
    border-bottom: 1px solid var(--oc-border);
    margin-bottom: 20px;
  }
  .product__name {
    font-size: 1.6rem;
    color: var(--oc-brand);
  }
  .product__tagline {
    margin: 4px 0 0;
    color: var(--oc-text-muted);
    font-size: 0.96rem;
  }
  .product__meta {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 9px;
    font-size: 0.92rem;
    color: var(--oc-text-muted);
    margin: 0;
  }
  .dot {
    color: var(--oc-border-input);
  }
  .product__store {
    margin-bottom: 20px;
  }

  /* ---------- Release rows (shared with downloads/[product]) ---------- */
  .releases {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 14px;
  }
  .release {
    border: 1px solid var(--oc-border);
    border-radius: var(--radius-sm);
    padding: 18px 20px;
    transition: border-color 0.18s ease;
  }
  .release:hover {
    border-color: var(--oc-border-input);
  }
  .release__head {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 8px;
  }
  .release__version {
    font-family: var(--font-mono);
    font-weight: 500;
    font-size: 1.05rem;
    color: var(--oc-brand);
  }
  .release__badge {
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    padding: 2px 9px;
    border-radius: 999px;
    background: var(--oc-success);
    color: #fff;
  }
  .release__date {
    margin-left: auto;
    font-size: 0.86rem;
    color: var(--oc-text-muted);
  }
  .release__facts {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 8px;
    font-size: 0.9rem;
    color: var(--oc-text-muted);
    margin-bottom: 12px;
  }
  .release__fallback {
    margin: 0;
    color: var(--oc-text-muted);
    font-size: 0.96rem;
  }

  /* ---------- Binary download buttons (shared with downloads pages) ---------- */
  .downloads {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(190px, 1fr));
    gap: 12px;
  }
  .download {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 14px 16px;
    border: 1px solid var(--oc-border-input);
    border-radius: var(--radius-sm);
    background: var(--oc-bg);
    color: var(--oc-text);
    transition:
      transform 0.16s ease,
      border-color 0.16s ease,
      box-shadow 0.16s ease;
  }
  .download:hover {
    text-decoration: none;
    transform: translateY(-2px);
    border-color: var(--oc-primary);
    box-shadow: var(--shadow-md);
  }
  .download__os {
    font-weight: 700;
    color: var(--oc-brand);
    white-space: nowrap;
  }
  .download__arch {
    font-family: var(--font-mono);
    font-size: 0.82rem;
    color: var(--oc-text-muted);
    white-space: nowrap;
  }
  .download__size {
    margin-left: auto;
    padding-left: 8px;
    font-size: 0.82rem;
    color: var(--oc-text-muted);
    white-space: nowrap;
  }
</style>
